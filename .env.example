# ─── Sanity (shared by web + studio) ───────────────────────────────
# Public project info (safe to expose). Find these in sanity.io/manage.
PUBLIC_SANITY_PROJECT_ID=your_project_id
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2024-01-01

# Server-only read token. Only needed if you query drafts/private data.
# Public published reads need NO token.
SANITY_READ_TOKEN=

# ─── Webhook rebuild (web server) ──────────────────────────────────
# Shared secret that /api/rebuild verifies against the Sanity webhook.
SANITY_WEBHOOK_SECRET=change_me_to_a_long_random_string

# ─── Contact form email ────────────────────────────────────────────
# Option A: Resend (recommended)
RESEND_API_KEY=
CONTACT_TO_EMAIL=you@example.com
CONTACT_FROM_EMAIL=site@yourdomain.dev

# Option B: SMTP (if you prefer Nodemailer) — leave Resend blank to use these
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── Newsletter ────────────────────────────────────────────────────
# Option A: Buttondown
BUTTONDOWN_API_KEY=
# Option B: self-hosted Listmonk
LISTMONK_URL=
LISTMONK_TOKEN=
LISTMONK_LIST_ID=
