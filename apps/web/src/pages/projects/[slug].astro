---
export const prerender = false;

import Base from "../../layouts/Base.astro";
import PortableText from "../../lib/portableText.astro";
import { sanityFetch } from "../../lib/sanity";
import { urlFor } from "../../lib/image";
import { PROJECT_BY_SLUG } from "../../lib/queries";

const { slug } = Astro.params;
const proj = slug
  ? await sanityFetch<any>(PROJECT_BY_SLUG, { runtime: true, params: { slug } })
  : null;

if (!proj) {
  Astro.response.status = 404;
}

const hero = proj?.hero ? urlFor(proj.hero)?.width(1400).auto("format").url() : null;
---

<Base title={`${proj?.name ?? "Project not found"} — Tushar Jaryal`} description={proj?.summary} runtime={true}>
  <div class="crumb">
    <a href="/projects">projects</a> <span class="sep">/</span> <span class="accent">{proj?.name}</span>
  </div>

  <header class="head">
    <div>
      <h1>{proj?.name}</h1>
      <p class="intro">{proj?.intro}</p>
      <div class="links">
        {proj?.links?.source && <a href={proj.links.source} class="btn primary">source &rarr;</a>}
        {proj?.links?.demo && <a href={proj.links.demo} class="btn ghost">live demo &rarr;</a>}
      </div>
    </div>
    <div class="facts">
      <div><span class="muted">year</span> {proj?.year}</div>
      {proj?.role && <div><span class="muted">role</span> {proj.role}</div>}
      {proj?.stack?.length > 0 && <div><span class="muted">stack</span> <span class="accent2">{proj.stack.join(" · ")}</span></div>}
      {proj?.status && <div><span class="muted">status</span> <span class="accent2">{proj.status}</span></div>}
    </div>
  </header>

  <div class="hero">
    {hero
      ? <img src={hero} alt={proj?.hero?.alt ?? proj?.name} />
      : <span class="ph">[ hero — system architecture diagram ]</span>}
  </div>

  {proj?.stats?.length > 0 && (
    <section class="stats">
      {proj.stats.map((s) => (
        <div class="stat"><div class="sv">{s.value}</div><div class="sl">{s.label}</div></div>
      ))}
    </section>
  )}

  {proj?.problem?.length > 0 && (
    <section class="seg">
      <div class="seg-label"># the problem</div>
      <PortableText value={proj.problem} />
    </section>
  )}
  {proj?.approach?.length > 0 && (
    <section class="seg">
      <div class="seg-label"># the approach</div>
      <PortableText value={proj.approach} />
    </section>
  )}
  {proj?.outcome?.length > 0 && (
    <section class="seg">
      <div class="seg-label"># the outcome</div>
      <div>
        <PortableText value={proj.outcome} />
        {proj?.testimonial?.quote && (
          <blockquote class="tq">"{proj.testimonial.quote}" — {proj.testimonial.attribution}</blockquote>
        )}
      </div>
    </section>
  )}

  <nav class="pager">
    <a href="/projects" class="muted">&larr; all projects</a>
    {proj?.next && (
      <a href={`/projects/${proj.next.slug}`} class="next">
        <span class="muted">next project</span><br /><span class="nname">{proj.next.name} &rarr;</span>
      </a>
    )}
  </nav>
</Base>

<style>
  .muted { color: var(--muted); }
  .accent { color: var(--accent); }
  .accent2 { color: var(--accent2); }
  .crumb { font-size: 12px; color: var(--muted); padding: 28px 0 0; }
  .crumb a { color: var(--muted); }
  .sep { color: var(--line); }
  .head { padding: 24px 0 36px; display: grid; grid-template-columns: 1.5fr 1fr; gap: 40px; align-items: end; border-bottom: 1px solid var(--line); }
  @media (max-width: 760px) { .head { grid-template-columns: 1fr; } }
  h1 { font-family: "Space Grotesk", sans-serif; font-weight: 700; font-size: clamp(40px, 7vw, 76px); line-height: 1; letter-spacing: -0.03em; }
  .intro { font-size: 16px; color: var(--muted); margin-top: 18px; max-width: 520px; }
  .links { display: flex; gap: 12px; margin-top: 24px; flex-wrap: wrap; }
  .btn { padding: 11px 18px; font-size: 13px; font-weight: 600; border-radius: 3px; }
  .btn.primary { background: var(--ink); color: var(--bg); }
  .btn.ghost { border: 1px solid var(--line); }
  .facts { font-size: 13px; line-height: 2.1; }
  .hero { aspect-ratio: 21/9; border: 1px solid var(--line); border-radius: 8px; margin: 40px 0; background: repeating-linear-gradient(45deg, var(--surface), var(--surface) 13px, transparent 13px, transparent 26px); display: grid; place-items: center; overflow: hidden; }
  .hero img { width: 100%; height: 100%; object-fit: cover; }
  .ph { font-size: 13px; color: var(--muted); background: var(--bg); padding: 8px 14px; border: 1px solid var(--line); border-radius: 3px; }
  .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1px; background: var(--line); border: 1px solid var(--line); border-radius: 8px; overflow: hidden; margin-bottom: 64px; }
  .stat { background: var(--surface); padding: 26px 22px; }
  .sv { font-family: "Space Grotesk", sans-serif; font-size: 34px; font-weight: 700; color: var(--accent); letter-spacing: -0.02em; }
  .sl { font-size: 12px; color: var(--muted); margin-top: 6px; }
  .seg { display: grid; grid-template-columns: 200px 1fr; gap: 40px; margin-bottom: 56px; }
  @media (max-width: 760px) { .seg { grid-template-columns: 1fr; gap: 12px; } }
  .seg-label { font-size: 13px; color: var(--accent); letter-spacing: 0.06em; text-transform: uppercase; align-self: start; }
  .tq { border-left: 2px solid var(--accent); padding-left: 18px; margin-top: 22px; font-style: italic; color: var(--muted); font-family: "Newsreader", serif; }
  .pager { display: flex; justify-content: space-between; border-top: 1px solid var(--line); padding: 28px 0; margin-bottom: 70px; gap: 16px; flex-wrap: wrap; font-size: 13px; }
  .next { text-align: right; }
  .nname { font-family: "Space Grotesk", sans-serif; font-size: 18px; font-weight: 600; }
</style>
