---
export const prerender = false;

import Base from "../../layouts/Base.astro";
import PortableText from "../../lib/portableText.astro";
import ReadingProgress from "../../components/ReadingProgress.tsx";
import { sanityFetch } from "../../lib/sanity";
import { POST_BY_SLUG } from "../../lib/queries";

const { slug } = Astro.params;
const post = slug
  ? await sanityFetch<any>(POST_BY_SLUG, { runtime: true, params: { slug } })
  : null;

if (!post) {
  Astro.response.status = 404;
}

const fmt = (d: string) => (d ? d.replaceAll("-", ".") : "");
const tagLine = post?.tags?.join(" · ");
---

<Base title={`${post?.title ?? "Post not found"} — Tushar Jaryal`} description={post?.excerpt} runtime={true}>
  <ReadingProgress client:idle />

  <article class="article-wrap">
    <div class="crumb"><a href="/blog">blog</a> <span class="sep">/</span> {fmt(post?.date)}</div>
    <h1>{post?.title}</h1>
    <div class="byline">
      <span class="author"><span class="glyph">夏</span> Tushar Jaryal</span>
      <span>·</span><span>{post?.readingTime} read</span><span>·</span>
      <span class="accent2">{tagLine}</span>
    </div>

    <div class="cover"><span class="ph">[ cover figure ]</span></div>

    <PortableText value={post?.body ?? []} />

    {post?.tags?.length > 0 && (
      <div class="tags">{post.tags.map((t) => <span class="tag">{t}</span>)}</div>
    )}

    <div class="author-card">
      <div class="glyph-lg">夏</div>
      <div>Written by <strong>Tushar Jaryal</strong> — ML engineer & developer. I write about putting models into production without losing sleep. <a href="/about" class="lnk">More about me &rarr;</a></div>
    </div>
  </article>

  {post?.related?.length > 0 && (
    <div class="related">
      <div class="rel-h">// keep reading</div>
      {post.related.map((r) => (
        <a href={`/blog/${r.slug}`} class="rel-row">
          <span class="rel-title">{r.title}</span>
          <span class="rel-read">{r.readingTime}</span>
        </a>
      ))}
    </div>
  )}
</Base>

<style>
  .accent2 { color: var(--accent2); }
  .article-wrap { max-width: 720px; margin: 0 auto; padding: 56px 0 40px; }
  .crumb { font-size: 12px; color: var(--muted); }
  .crumb a { color: var(--muted); }
  .sep { color: var(--line); }
  h1 { font-family: "Space Grotesk", sans-serif; font-weight: 700; font-size: clamp(34px, 5vw, 52px); line-height: 1.08; letter-spacing: -0.025em; margin-top: 18px; }
  .byline { display: flex; align-items: center; gap: 16px; margin-top: 24px; font-size: 12px; color: var(--muted); flex-wrap: wrap; }
  .author { display: flex; align-items: center; gap: 8px; }
  .glyph { display: grid; place-items: center; width: 26px; height: 26px; border: 1px solid var(--ink); font-size: 11px; }
  .cover { aspect-ratio: 16/8; border: 1px solid var(--line); border-radius: 8px; margin: 36px 0 8px; background: repeating-linear-gradient(45deg, var(--surface), var(--surface) 12px, transparent 12px, transparent 24px); display: grid; place-items: center; }
  .ph { font-size: 12px; color: var(--muted); background: var(--bg); padding: 6px 11px; border: 1px solid var(--line); border-radius: 2px; }
  .tags { display: flex; gap: 8px; margin-top: 44px; flex-wrap: wrap; }
  .tag { font-size: 11px; color: var(--accent2); border: 1px solid var(--line); padding: 4px 10px; border-radius: 3px; }
  .author-card { display: flex; align-items: center; gap: 16px; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); padding: 28px 0; margin-top: 40px; font-size: 13px; color: var(--muted); line-height: 1.6; }
  .glyph-lg { display: grid; place-items: center; width: 48px; height: 48px; border: 1.5px solid var(--ink); font-size: 18px; flex-shrink: 0; }
  .lnk { color: var(--accent); }
  .related { max-width: 720px; margin: 0 auto; padding: 0 0 80px; }
  .rel-h { font-size: 13px; color: var(--accent); letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 18px; }
  .rel-row { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; padding: 20px 8px; border-bottom: 1px solid var(--line); }
  .rel-title { font-family: "Space Grotesk", sans-serif; font-size: 18px; font-weight: 600; }
  .rel-read { font-size: 12px; color: var(--muted); white-space: nowrap; }
</style>
