---
import Base from "../layouts/Base.astro";
import ContactForm from "../components/ContactForm.tsx";
import { sanityFetch } from "../lib/sanity";
import { CONTACT } from "../lib/queries";

const data = (await sanityFetch<any>(CONTACT)) ?? {};
const directLinks = data.directLinks ?? [];
const availability = data.availability ?? { timezone: "", replies: "", openTo: [] };
---

<Base title="Contact — Tushar Jaryal" description={data.intro}>
  <header class="head">
    <div class="eyebrow">{data.eyebrow}</div>
    <h1>{data.heading}</h1>
    <p class="intro serif">{data.intro}</p>
  </header>

  <section class="grid">
    <div class="panel">
      <div class="bar">
        <span class="d d1"></span><span class="d d2"></span><span class="d d3"></span>
        <span class="bar-label">~/new-message</span>
      </div>
      <div class="form-wrap">
        <ContactForm client:visible />
      </div>
    </div>

    <div class="side">
      <div class="eyebrow">// direct lines</div>
      {directLinks.map((l) => (
        <a href={l.href} class="tile">
          <div>
            <div class="t-label">{l.label}</div>
            <div class="t-value">{l.value}</div>
          </div>
          <span class="t-arrow">&rarr;</span>
        </a>
      ))}
      <div class="avail">
        <div><span class="accent2">timezone</span> = {availability.timezone}</div>
        <div><span class="accent2">replies</span> = {availability.replies}</div>
        <div><span class="accent2">open_to</span> = [{(availability.openTo ?? []).map((o) => `"${o}"`).join(", ")}]</div>
      </div>
    </div>
  </section>
</Base>

<style>
  .accent2 { color: var(--accent2); }
  .head { padding: 64px 0 36px; }
  .eyebrow { font-size: 12px; color: var(--accent); letter-spacing: 0.06em; text-transform: uppercase; }
  h1 { font-family: "Space Grotesk", sans-serif; font-weight: 700; font-size: clamp(36px, 6vw, 68px); line-height: 1.05; letter-spacing: -0.03em; margin-top: 16px; max-width: 720px; }
  .intro { font-size: 19px; color: var(--muted); margin-top: 18px; max-width: 560px; line-height: 1.6; }
  .grid { display: grid; grid-template-columns: 1.3fr 1fr; gap: 48px; align-items: start; margin-bottom: 90px; }
  @media (max-width: 760px) { .grid { grid-template-columns: 1fr; } }
  .panel { border: 1px solid var(--line); background: var(--surface); border-radius: 8px; overflow: hidden; }
  .bar { display: flex; align-items: center; gap: 8px; padding: 11px 16px; border-bottom: 1px solid var(--line); }
  .d { width: 11px; height: 11px; border-radius: 50%; }
  .d1 { background: var(--accent); } .d2 { background: var(--muted); opacity: 0.5; } .d3 { background: var(--accent2); }
  .bar-label { margin-left: 8px; font-size: 12px; color: var(--muted); }
  .form-wrap { padding: 26px 24px; }
  .side { display: flex; flex-direction: column; gap: 14px; }
  .tile { display: flex; align-items: center; justify-content: space-between; gap: 12px; border: 1px solid var(--line); background: var(--surface); border-radius: 6px; padding: 16px 18px; transition: border-color 0.15s ease, transform 0.15s ease; }
  .tile:hover { border-color: var(--accent); transform: translateX(3px); }
  .t-label { font-size: 11px; color: var(--muted); }
  .t-value { font-family: "Space Grotesk", sans-serif; font-size: 15px; font-weight: 600; margin-top: 3px; }
  .t-arrow { font-size: 16px; color: var(--accent); }
  .avail { border: 1px solid var(--line); border-radius: 6px; padding: 18px; font-size: 12px; color: var(--muted); line-height: 1.8; margin-top: 4px; }
</style>
